# Stage 1: The Builder
FROM maven:3.9-eclipse-temurin-17 AS builder

# Accept build args for GitHub authentication
ARG GITHUB_USER
ARG GITHUB_TOKEN

# Expose them as environment variables for Maven
ENV GITHUB_USER=${GITHUB_USER}
ENV GITHUB_TOKEN=${GITHUB_TOKEN}

WORKDIR /app

# Copy only the files needed to download dependencies for layer caching
COPY .mvn .mvn
COPY mvnw pom.xml ./

# Make Maven wrapper executable
RUN chmod +x ./mvnw

# Mount and decode Maven settings in-container
RUN --mount=type=secret,id=maven-settings \
    mkdir -p /root/.m2 && \
    cat /run/secrets/maven-settings | base64 -d > /root/.m2/settings.xml && \
    ./mvnw dependency:go-offline -B

# Copy the rest of the source code
COPY src ./src

# Build the package skipping tests
RUN --mount=type=secret,id=maven-settings \
    cat /run/secrets/maven-settings | base64 -d > /root/.m2/settings.xml && \
    ./mvnw clean package -DskipTests -B

# Stage 2: The Runtime Image
FROM openjdk:17-jdk-slim

ENV SPRING_PROFILES_ACTIVE=dev
LABEL version="dev"
LABEL description="Table2Table Payment Service - Development build"

# Create non-root user
RUN groupadd -g 1001 appuser && useradd -u 1001 -g appuser -m appuser
WORKDIR /app

# Copy built JAR and set ownership
COPY --from=builder /app/target/*.jar app.jar
RUN chown appuser:appuser app.jar
USER appuser

# Expose port and healthcheck
EXPOSE 8085
HEALTHCHECK --interval=30s --timeout=3s --start-period=40s --retries=3 \
    CMD curl -f http://localhost:8085/actuator/health || exit 1

ENTRYPOINT ["java", "-jar", "app.jar"]
